root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{py,qml,js,xml,json,sh}]
indent_style = space
indent_size = 4
max_line_length = 120

[Makefile]
indent_style = tab
